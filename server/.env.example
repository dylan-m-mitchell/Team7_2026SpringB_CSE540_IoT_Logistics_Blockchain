# HTTP server port
PORT=3000

# Off-chain SQLite database path (relative to server/)
DB_PATH=./data/tracker.db

# Local Fabric wallet directory (where admin/user identities are stored)
WALLET_PATH=./wallet

# Identity label inside the wallet to use for contract calls
FABRIC_IDENTITY=admin

# MSP id for the identity above (Org1MSP for the default test-network admin)
FABRIC_MSP_ID=Org1MSP

# Path to the Fabric test-network checkout. Used by enroll-admin and gateway connection.
# Defaults assume the layout from SETUP.md.
FABRIC_TESTNET=/home/dylan/fabric-samples/test-network

# Path to a Fabric connection profile JSON for the chosen org.
# Default points at the Org1 connection profile produced by ./network.sh up.
FABRIC_CONNECTION_PROFILE=${FABRIC_TESTNET}/organizations/peerOrganizations/org1.example.com/connection-org1.json

# Channel + chaincode name (must match deployCC arguments)
FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=assetTransfer

# Default API URL used by the CLI when --api-url is not provided
API_URL=http://localhost:3000
